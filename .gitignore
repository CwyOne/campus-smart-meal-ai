# ===========================================
# 校园智餐通管理平台（AI增强版） .gitignore
# ===========================================


# ==================== 操作系统文件 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory


# ==================== IDE 配置 ====================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# VS Code
.vscode/
*.code-workspace

# Eclipse
.project
.classpath
.settings/
build/

# NetBeans
nbproject/
nbbuild/
nbdist/
nb-configuration.xml


# ==================== Java / Maven 产物 ====================
# 编译产物（所有模块）
**/target/
*.class
*.jar
*.war
*.ear

# Maven
.mvn/
mvnw
mvnw.cmd
!.mvn/wrapper/maven-wrapper.jar

# 日志文件
*.log
logs/
log/

# Spring Boot 热加载
.springBeans
rebel.xml


# ==================== 敏感配置与密钥 ====================
# 本地开发环境配置（含数据库密码、API密钥）
**/application-dev.yml
**/application-local.yml
**/application-test.yml
**/project.private.config.json

# 密钥证书文件
*.key
*.pem
*.crt
*.p12
*.jks
*.keystore

# 环境变量文件
.env
.env.local
.env.*.local


# ==================== Vue 前端产物 ====================
# 依赖目录
**/node_modules/

# 打包产物
**/dist/
**/build/

# Vue 环境配置（本地开发）
project-sky-admin-vue-ts/.env.development
project-sky-admin-vue-ts/.env.staging
project-sky-admin-vue-ts/.env.production.uat

# npm / yarn 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 缓存
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo

# 测试覆盖率
coverage/
.nyc_output/


# ==================== 原项目遗留文件 ====================
# 原 Git 历史
.git/
.github/

# 原项目报告文件
report.*.json

# 原 LICENSE 文件
LICENSE


# ==================== 临时与备份文件 ====================
# 临时文件
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# 截图与临时图片
*.png
*.jpg
*.jpeg
*.gif
!docs/assets/*

# Excel / 文本备份
*.xlsx
*.xls
*.csv
!docs/**/*.xlsx
!docs/**/*.csv

# 压缩包
*.zip
*.tar.gz
*.rar
*.7z


# ==================== 其他 ====================
# 本地运行配置
*.local
local.properties

# PWA
service-worker.js
precache-manifest.*.js

# 构建分析
stats.json
bundle-analyzer-report.html
